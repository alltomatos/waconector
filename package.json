{
  "name": "waconector",
  "version": "0.1.0",
  "description": "Conector universal para APIs não-oficiais de WhatsApp — um contrato único, um adapter por provider.",
  "keywords": [
    "whatsapp",
    "whatsapp-api",
    "evolution-api",
    "waha",
    "uazapi",
    "z-api",
    "whapi",
    "wuzapi",
    "quepasa",
    "zapo",
    "chatbot",
    "sdk"
  ],
  "homepage": "https://github.com/alltomatos/waconector#readme",
  "bugs": {
    "url": "https://github.com/alltomatos/waconector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alltomatos/waconector.git"
  },
  "license": "MIT",
  "author": "Alltomatos",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "require": {
        "types": "./dist/testing/index.d.cts",
        "default": "./dist/testing/index.cjs"
      }
    },
    "./waha": {
      "import": {
        "types": "./dist/adapters/waha/index.d.ts",
        "default": "./dist/adapters/waha/index.js"
      },
      "require": {
        "types": "./dist/adapters/waha/index.d.cts",
        "default": "./dist/adapters/waha/index.cjs"
      }
    },
    "./evolution": {
      "import": {
        "types": "./dist/adapters/evolution/index.d.ts",
        "default": "./dist/adapters/evolution/index.js"
      },
      "require": {
        "types": "./dist/adapters/evolution/index.d.cts",
        "default": "./dist/adapters/evolution/index.cjs"
      }
    },
    "./uazapi": {
      "import": {
        "types": "./dist/adapters/uazapi/index.d.ts",
        "default": "./dist/adapters/uazapi/index.js"
      },
      "require": {
        "types": "./dist/adapters/uazapi/index.d.cts",
        "default": "./dist/adapters/uazapi/index.cjs"
      }
    },
    "./zapi": {
      "import": {
        "types": "./dist/adapters/zapi/index.d.ts",
        "default": "./dist/adapters/zapi/index.js"
      },
      "require": {
        "types": "./dist/adapters/zapi/index.d.cts",
        "default": "./dist/adapters/zapi/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "smoke": "node scripts/smoke.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/cli": "2.31.0",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
